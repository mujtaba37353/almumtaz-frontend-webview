{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "API_URL": "http://localhost:5000/api"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_URL": "https://api.mumtaz.app/api"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "API_URL": "https://api.mumtaz.app/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
